# HANOON Trading Bot — copy to .env and fill in your values
# cp .env.example .env

# Interactive Brokers
IB_HOST=127.0.0.1
IB_PORT=4002
# CLIENT_ID=1

# Ollama generative AI — 2.5GB reserved on 8GB Mac (warm model, frequent decisions)
GENERATIVE_THINKING_ENABLED=true
AI_FULL_CONTROL=true
AI_STATIC_FALLBACK=false
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_MEMORY_BUDGET_MB=2560
OLLAMA_TIMEOUT=20
OLLAMA_MAX_TOKENS=256
OLLAMA_KEEP_ALIVE=600
OLLAMA_NUM_CTX=2048
AI_ALWAYS_ACTIVE=true
OLLAMA_DECISION_BYPASS_RATE_LIMIT=true
OLLAMA_DECISION_MIN_FREE_RAM_MB=768
OLLAMA_MIN_CALL_INTERVAL_SEC=1
OLLAMA_UNLOAD_AFTER_CALL=false
OLLAMA_MIN_FREE_RAM_MB=1024
OLLAMA_META_OPTIMIZER_ENABLED=false

# Hybrid distillation (Qwen teacher → fast PPO proxy, automatic)
HYBRID_DISTILLATION_ENABLED=true
HYBRID_DISTILL_MIN_TRADES=100
HYBRID_DISTILL_FULL_TRADES=500

# Live AI hotline — Ollama always on, async parallel with PPO (no stale cache)
LIVE_AI_PIPELINE_ENABLED=true
LIVE_AI_MAX_AGE_SEC=4
LIVE_AI_PREFETCH_TOP_N=3

# Telegram notifications (optional)
TRADING_BOT_TELEGRAM_TOKEN=
TRADING_BOT_TELEGRAM_CHAT_ID=

# GitHub sync (optional) — use owner/repo format; github.com is added automatically
GITHUB_TOKEN=
GITHUB_FORCE_CLI=true
GITHUB_HANOON_REPO=your-user/trading-bot-HA-NUN
GITHUB_GRANDMASTER_REPO=your-user/trading-bot-Grandmaster
GITHUB_LOGS_REPO=your-user/trading-bot-Logs
# Optional 4th private repo (experiments — not auto-synced)
# GITHUB_ALGO_REPO=your-user/Algo
