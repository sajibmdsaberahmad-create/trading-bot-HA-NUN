# HANOON Trading Bot — copy to .env and fill in your values
# cp .env.example .env

# Interactive Brokers
IB_HOST=127.0.0.1
IB_PORT=4002
# CLIENT_ID=1

# ════════════════════════════════════════════════════════════════════
# CLOUD COUNCIL — Groq primary, Gemini fallback (no local Ollama)
# ════════════════════════════════════════════════════════════════════
COUNCIL_ENABLED=true
COUNCIL_BACKEND=groq
GROQ_API_KEY=
GEMINI_API_KEY=
# Alias for GEMINI_API_KEY:
# GOOGLE_API_KEY=

GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant
GEMINI_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash

GENERATIVE_THINKING_ENABLED=true
AI_FULL_CONTROL=true
AI_COUNCIL_ALL_DECISIONS=true
AI_COUNCIL_MAX_WAIT_SEC=4
COUNCIL_TIMEOUT_SEC=12
COUNCIL_MAX_TOKENS=384
COUNCIL_MIN_CALL_INTERVAL_SEC=0.5

# API budget — save Groq/Gemini RPM for live council (entry/exit)
COUNCIL_BUDGET_ENABLED=true
COUNCIL_NOTIFY_API_ENABLED=false
COUNCIL_NOTIFY_API_COPILOT=true
COUNCIL_NOTIFY_API_TRADES=false
COUNCIL_RUNTIME_LLM_ENABLED=false
COUNCIL_GENERATIVE_RTH_ENABLED=false
COUNCIL_DAILY_DIGEST_ENABLED=true
COUNCIL_MOOD_API_ENABLED=false
COUNCIL_CHART_VISION_API_ENABLED=false
COUNCIL_NOTIFY_MAX_PER_MIN=6
COUNCIL_NOTIFY_MIN_GAP_SEC=20

# Cross-device secrets (encrypted — safe in private git)
ENV_SYNC_ENABLED=true
ENV_SYNC_PUSH_KEY=true
DEFERRED_COUNCIL_LEARNING=true
PPO_LEARN_EVERY_ENTRY=true

# Live AI hotline — async council parallel with PPO
LIVE_AI_PIPELINE_ENABLED=true
LIVE_AI_MAX_AGE_SEC=4
LIVE_AI_MIN_RING_SEC=0.8
LIVE_AI_PREFETCH_TOP_N=3

# Chart vision (Gemini multimodal)
LIVE_CHART_VISION_ENABLED=false
LIVE_CHART_VISION_OPPORTUNISTIC=true
CHART_VISION_ENTRY_ONLY=true

# Hybrid distillation (council teacher → fast PPO proxy)
HYBRID_DISTILLATION_ENABLED=true
HYBRID_DISTILL_MIN_TRADES=100
HYBRID_DISTILL_FULL_TRADES=500
HYBRID_DISTILL_AUTO_FAST_PATH=false

# Telegram notifications (optional)
TRADING_BOT_TELEGRAM_TOKEN=
TRADING_BOT_TELEGRAM_CHAT_ID=

# GitHub sync (optional)
GITHUB_TOKEN=
GITHUB_FORCE_CLI=true
GITHUB_HANOON_REPO=sajibmdsaberahmad-create/HANOON
GITHUB_CLEAN_ALGO_REPO=sajibmdsaberahmad-create/HANOON
HANOON_CLEAN_REPO_AUTO_PUBLISH=true
HANOON_CLEAN_PUBLISH_MIN_SEC=3600
GITHUB_GRANDMASTER_REPO=your-user/trading-bot-Grandmaster
GITHUB_LOGS_REPO=your-user/trading-bot-Logs
