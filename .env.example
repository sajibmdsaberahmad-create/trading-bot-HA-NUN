# ════════════════════════════════════════════════════════════════════════════════
# HA-NUN TRADING BOT — ENVIRONMENT VARIABLES
# ════════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to Git.

# ════════════════════════════════════════════════════════════════════════════════
# GITHUB (Multi-Repo Architecture)
# ════════════════════════════════════════════════════════════════════════════════
GITHUB_TOKEN=ghp_your_token_here
GITHUB_REPO=https://github.com/sajibmdsaberahmad-create/trading-bot-HA-NUN.git
GITHUB_HA_NUN_REPO=https://github.com/sajibmdsaberahmad-create/trading-bot-HA-NUN.git
GITHUB_GRANDMASTER_REPO=https://github.com/sajibmdsaberahmad-create/trading-bot-Grandmaster.git
GITHUB_LOGS_REPO=https://github.com/sajibmdsaberahmad-create/trading-bot-Logs.git

# ════════════════════════════════════════════════════════════════════════════════
# HUGGING FACE HUB (Model Registry)
# ════════════════════════════════════════════════════════════════════════════════
HF_TOKEN=hf_your_token_here
HF_REPO_ID=sajibmdsaberahmad-create/trading-bot-HA-NUN

# ════════════════════════════════════════════════════════════════════════════════
# INTERACTIVE BROKERS GATEWAY
# ════════════════════════════════════════════════════════════════════════════════
# Ports:
#   4002  = IB Gateway (paper)
#   4001  = IB Gateway (live)
#   7497  = TWS (paper)
#   7496  = TWS (live)
IB_HOST=127.0.0.1
IB_PORT=4002
IB_CLIENT_ID=1
PAPER_TRADING=true

# ════════════════════════════════════════════════════════════════════════════════
# TELEGRAM NOTIFICATIONS
# ════════════════════════════════════════════════════════════════════════════════
TRADING_BOT_TELEGRAM_TOKEN=123456:ABC-DEF...
TRADING_BOT_TELEGRAM_CHAT_ID=123456789

# ════════════════════════════════════════════════════════════════════════════════
# OLLAMA LLM REASONING HEAD
# ════════════════════════════════════════════════════════════════════════════════
OLLAMA_ENABLED=false
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT=10
OLLAMA_MAX_TOKENS=256
OLLAMA_TEMPERATURE=0.7

# Meta-optimizer (active hyperparameter tuning)
OLLAMA_META_OPTIMIZER_ENABLED=true
META_OPTIMIZER_MODEL=llama3:70b-instruct
MAX_PARAM_MUTATIONS_PER_DAY=5