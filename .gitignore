# ════════════════════════════════════════════════════════════════════════════════
# HANOON TRADING BOT — INSTITUTIONAL GRADE .gitignore
# ════════════════════════════════════════════════════════════════════════════════
# Multi-Repo Architecture: HANOON (live) / Grandmaster (weights) / Logs

# ════════════════════════════════════════════════════════════════════════════════
# CRITICAL: NEVER COMMIT THESE
# ════════════════════════════════════════════════════════════════════════════════
.env
*.pem
*.key
credentials.json
secrets.yaml
__pycache__/
*.pyc
*.pyo
*.pyd

# ════════════════════════════════════════════════════════════════════════════════
# DATA BLOAT GUARD — Only 30-day rolling window in Git
# ════════════════════════════════════════════════════════════════════════════════
# Raw CSV data (pushed to Logs repo, not HANOON)
data/live_market_features.csv
data/*.csv
backtest_results/results_latest.csv
backtest_results/results_*.csv
**/results_latest.csv

# Experience buffer (large JSONL)
models/experience_buffer.jsonl

# Large binary model files — NEVER commit raw weights to Git.
# Preserve via GitHub Releases / Hugging Face Hub instead.
*.zip
*.pt
*.pth
*.h5
*.ckpt
*.onnx
*.bin
models/*.zip
models/*.pt
models/*.pth
models/*.h5
models/*.ckpt
models/*.onnx
models/checkpoints/
models/backups/
checkpoints/
backups/

# ════════════════════════════════════════════════════════════════════════════════
# LOGS (Push to Logs repo if needed, otherwise local only)
# ════════════════════════════════════════════════════════════════════════════════
*.log
logs/
models/daily_reports/*.json
!models/daily_reports/.gitkeep

# ════════════════════════════════════════════════════════════════════════════════
# PYTHON / IDE
# ════════════════════════════════════════════════════════════════════════════════
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
ENV/
env.bak/
venv.bak/
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ════════════════════════════════════════════════════════════════════════════════
# JUPYTER / COLAB
# ════════════════════════════════════════════════════════════════════════════════
.ipynb_checkpoints
*.ipynb
!colab_training.ipynb

# ════════════════════════════════════════════════════════════════════════════════
# TENSORFLOW / PYTORCH ARTIFACTS
# ════════════════════════════════════════════════════════════════════════════════
*.pb
tensorboard/
runs/
lightning_logs/
model.ckpt
*.onnx
*.pt

# ════════════════════════════════════════════════════════════════════════════════
# OS / SYSTEM
# ════════════════════════════════════════════════════════════════════════════════
Thumbs.db
Desktop.ini